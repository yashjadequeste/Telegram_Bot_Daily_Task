# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_numeric_chat_id

# Groq AI
GROQ_API_KEY=your_groq_key

# Gmail
EMAIL_SENDER=you@company.com
EMAIL_PASSWORD=your_gmail_app_password

# Multiple receivers (comma separated)
EMAIL_RECEIVERS=manager@company.com,boss@company.com

# 7 PM reminder (IST) — Mon to Fri only
REMINDER_HOUR=19
REMINDER_MINUTE=0

# Production on Render: false | Local test on weekend: true
ALLOW_WEEKEND_TEST=false

# Send test notification when app starts (local test only)
SEND_TEST_ON_START=false
